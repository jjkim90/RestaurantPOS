<Window x:Class="RestaurantPOS.WPF.WebView2TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="WebView2 Test Window" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Name="TestInitButton" Content="Test WebView2 Init" 
                    Click="TestInitButton_Click" 
                    Width="150" Height="40" Margin="5"/>
            <Button Name="LoadGoogleButton" Content="Load Google" 
                    Click="LoadGoogleButton_Click" 
                    Width="150" Height="40" Margin="5"
                    IsEnabled="False"/>
        </StackPanel>
        
        <wv2:WebView2 Grid.Row="1" Name="TestWebView" Margin="10"/>
        
        <TextBox Grid.Row="2" Name="StatusTextBox" 
                 Height="100" Margin="10" 
                 VerticalScrollBarVisibility="Auto"
                 IsReadOnly="True"
                 FontFamily="Consolas"/>
    </Grid>
</Window>