<dx:ThemedWindow x:Class="RestaurantPOS.WPF.Modules.MenuModule.Views.MenuItemEditDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 Title="{Binding Title}"
                 Height="500" Width="600"
                 WindowStartupLocation="CenterOwner"
                 ShowInTaskbar="False">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <dxlc:LayoutControl Grid.Row="0">
            <dxlc:LayoutGroup Orientation="Vertical">
                <dxlc:LayoutItem Label="Category:">
                    <dxe:ComboBoxEdit ItemsSource="{Binding Categories}"
                                     EditValue="{Binding CategoryId}"
                                     DisplayMember="CategoryName"
                                     ValueMember="CategoryId"/>
                </dxlc:LayoutItem>
                
                <dxlc:LayoutItem Label="Item Name:">
                    <dxe:TextEdit Text="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}" />
                </dxlc:LayoutItem>
                
                <dxlc:LayoutItem Label="Price:">
                    <dxe:SpinEdit Value="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                  MinValue="0" 
                                  MaxValue="999999"
                                  Mask="n0"
                                  MaskUseAsDisplayFormat="True"
                                  IsFloatValue="False"
                                  Increment="1000"/>
                </dxlc:LayoutItem>
                
                <dxlc:LayoutItem Label="Description:">
                    <dxe:TextEdit Text="{Binding Description}" 
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"/>
                </dxlc:LayoutItem>
                
                <dxlc:LayoutItem Label="Available:">
                    <CheckBox IsChecked="{Binding IsAvailable}" />
                </dxlc:LayoutItem>
            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>

        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <dx:SimpleButton Content="저장" 
                           IsDefault="True"
                           Width="120" 
                           Height="50"
                           FontSize="16"
                           Margin="0,0,10,0"
                           Click="SaveButton_Click"/>
            <dx:SimpleButton Content="취소" 
                           IsCancel="True"
                           Width="120"
                           Height="50"
                           FontSize="16"
                           Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</dx:ThemedWindow>