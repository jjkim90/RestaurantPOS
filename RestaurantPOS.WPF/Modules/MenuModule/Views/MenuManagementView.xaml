<UserControl x:Class="RestaurantPOS.WPF.Modules.MenuModule.Views.MenuManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading Overlay -->
        <dx:WaitIndicator Grid.Row="1" Visibility="{Binding IsLoading, Converter={dx:BooleanToVisibilityConverter}}" />

        <!-- Touch-friendly Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="White" Margin="10">
            <dx:SimpleButton Content="카테고리 추가" 
                             Command="{Binding AddCategoryCommand}"
                             Glyph="{dx:DXImage Image=AddNewDataSource_32x32.png}"
                             Width="180" Height="60" Margin="5" FontSize="16"/>
            <dx:SimpleButton Content="카테고리 수정" 
                             Command="{Binding EditCategoryCommand}"
                             Glyph="{dx:DXImage Image=EditDataSource_32x32.png}"
                             Width="180" Height="60" Margin="5" FontSize="16"/>
            <dx:SimpleButton Content="카테고리 삭제" 
                             Command="{Binding DeleteCategoryCommand}"
                             Glyph="{dx:DXImage Image=DeleteDataSource2_32x32.png}"
                             Width="180" Height="60" Margin="5" FontSize="16"/>
            <Border Width="2" Background="LightGray" Margin="10,0"/>
            <dx:SimpleButton Content="메뉴 추가" 
                             Command="{Binding AddMenuItemCommand}"
                             Glyph="{dx:DXImage Image=Add_32x32.png}"
                             Width="150" Height="60" Margin="5" FontSize="16"/>
            <dx:SimpleButton Content="메뉴 수정" 
                             Command="{Binding EditMenuItemCommand}"
                             Glyph="{dx:DXImage Image=Edit_32x32.png}"
                             Width="150" Height="60" Margin="5" FontSize="16"/>
            <dx:SimpleButton Content="메뉴 삭제" 
                             Command="{Binding DeleteMenuItemCommand}"
                             Glyph="{dx:DXImage Image=Delete_32x32.png}"
                             Width="150" Height="60" Margin="5" FontSize="16"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Categories Panel -->
            <dxlc:LayoutControl Grid.Column="0" Padding="10">
                <dxlc:LayoutGroup Header="Categories" View="GroupBox">
                    <dxg:GridControl ItemsSource="{Binding Categories}" 
                                    SelectedItem="{Binding SelectedCategory}"
                                    ShowBorder="False">
                        <dxg:GridControl.View>
                            <dxg:TableView ShowGroupPanel="False" 
                                          AllowEditing="False"
                                          ShowIndicator="False"
                                          NavigationStyle="Row"
                                          ShowVerticalLines="False"
                                          ShowHorizontalLines="True">
                                <dxg:TableView.RowStyle>
                                    <Style TargetType="dxg:RowControl">
                                        <Setter Property="FontSize" Value="16"/>
                                        <Setter Property="Height" Value="60"/>
                                    </Style>
                                </dxg:TableView.RowStyle>
                            </dxg:TableView>
                        </dxg:GridControl.View>
                        <dxg:GridColumn FieldName="CategoryName" Header="Name" Width="*"/>
                        <dxg:GridColumn FieldName="DisplayOrder" Header="Order" Width="60" HorizontalHeaderContentAlignment="Center"/>
                        <dxg:GridColumn FieldName="MenuItemCount" Header="Items" Width="60" HorizontalHeaderContentAlignment="Center"/>
                        <dxg:GridColumn FieldName="IsActive" Header="Active" Width="60" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Value}" IsEnabled="False" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                </dxlc:LayoutGroup>
            </dxlc:LayoutControl>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />

            <!-- Menu Items Panel -->
            <dxlc:LayoutControl Grid.Column="2" Padding="10">
                <dxlc:LayoutGroup Header="Menu Items" View="GroupBox">
                    <dxg:GridControl ItemsSource="{Binding MenuItems}" 
                                    SelectedItem="{Binding SelectedMenuItem}"
                                    ShowBorder="False">
                        <dxg:GridControl.View>
                            <dxg:TableView ShowGroupPanel="False" 
                                          AllowEditing="False"
                                          ShowIndicator="False"
                                          NavigationStyle="Row"
                                          ShowVerticalLines="False"
                                          ShowHorizontalLines="True">
                                <dxg:TableView.RowStyle>
                                    <Style TargetType="dxg:RowControl">
                                        <Setter Property="FontSize" Value="16"/>
                                        <Setter Property="Height" Value="60"/>
                                    </Style>
                                </dxg:TableView.RowStyle>
                            </dxg:TableView>
                        </dxg:GridControl.View>
                        <dxg:GridColumn FieldName="ItemName" Header="Name" Width="200"/>
                        <dxg:GridColumn FieldName="Price" Header="Price" Width="100">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings DisplayFormat="C" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="Description" Header="Description" Width="*"/>
                        <dxg:GridColumn FieldName="IsAvailable" Header="Available" Width="80" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Value}" IsEnabled="False" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                </dxlc:LayoutGroup>
            </dxlc:LayoutControl>
        </Grid>
    </Grid>
</UserControl>