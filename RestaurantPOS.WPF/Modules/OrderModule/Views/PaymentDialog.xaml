<dx:ThemedWindow 
    x:Class="RestaurantPOS.WPF.Modules.OrderModule.Views.PaymentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    Title="결제 처리" 
    Height="400" Width="500"
    WindowStartupLocation="CenterOwner">
    <dxlc:LayoutControl Padding="20">
        <dxlc:LayoutGroup Orientation="Vertical">
            <!-- 주문 정보 -->
            <dxlc:LayoutItem Label="주문번호:" LabelPosition="Left">
                <TextBlock Text="{Binding OrderNumber}" FontSize="16" FontWeight="Bold"/>
            </dxlc:LayoutItem>
            
            <dxlc:LayoutItem Label="테이블:" LabelPosition="Left">
                <TextBlock Text="{Binding TableName}" FontSize="16"/>
            </dxlc:LayoutItem>
            
            <dxlc:LayoutItem Label="총 금액:" LabelPosition="Left">
                <TextBlock Text="{Binding TotalAmountDisplay}" FontSize="20" FontWeight="Bold" Foreground="Blue"/>
            </dxlc:LayoutItem>
            
            <!-- 결제 방법 선택 -->
            <dxlc:GroupBox Header="결제 방법 선택" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <dx:SimpleButton Content="현금 결제" 
                                     Command="{Binding CashPaymentCommand}"
                                     Glyph="{dx:DXImage Image=Currency_16x16.png}"
                                     Width="150" Height="100" 
                                     Margin="10"
                                     FontSize="18"/>
                    
                    <dx:SimpleButton Content="카드 결제" 
                                     Command="{Binding CardPaymentCommand}"
                                     Glyph="{dx:DXImage Image=Card_16x16.png}"
                                     Width="150" Height="100" 
                                     Margin="10"
                                     FontSize="18"/>
                </StackPanel>
            </dxlc:GroupBox>
            
            <!-- 취소 버튼 -->
            <dxlc:LayoutItem HorizontalAlignment="Right" Margin="0,20,0,0">
                <dx:SimpleButton Content="취소" 
                                 Command="{Binding CancelCommand}"
                                 Width="100" Height="35"/>
            </dxlc:LayoutItem>
        </dxlc:LayoutGroup>
    </dxlc:LayoutControl>
</dx:ThemedWindow>