<UserControl x:Class="RestaurantPOS.WPF.Modules.OrderModule.Views.OrderManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars">
    
    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:EventToCommand EventName="Loaded" Command="{Binding LoadedCommand}"/>
    </dxmvvm:Interaction.Behaviors>
    
    <dx:DXTabControl>
        <!-- Main Order Tab -->
        <dx:DXTabItem Header="주문">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <dxlc:GroupBox Grid.Row="0" Header="테이블 정보" Margin="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{Binding TableDisplayName}" 
                                   FontSize="20" FontWeight="Bold" Margin="10,5"/>
                        
                        <dx:SimpleButton Grid.Column="2" Content="테이블 화면으로" 
                                         Command="{Binding BackToTableCommand}"
                                         Glyph="{dx:DXImage Image=Backward_16x16.png}"
                                         Margin="5"/>
                    </Grid>
                </dxlc:GroupBox>
                
                <!-- Main Content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Panel - Menu Selection -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Category Buttons -->
                        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <dx:SimpleButton Content="{Binding CategoryName}"
                                                         Command="{Binding DataContext.CategoryClickCommand, 
                                                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         CommandParameter="{Binding}"
                                                         Margin="5" Padding="15,10"
                                                         FontSize="14">
                                            <dx:SimpleButton.Style>
                                                <Style TargetType="dx:SimpleButton">
                                                    <Setter Property="Background" Value="LightGray"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="SteelBlue"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </dx:SimpleButton.Style>
                                        </dx:SimpleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        
                        <!-- Menu Items Grid -->
                        <dxlc:GroupBox Grid.Row="1" Header="메뉴 선택" Margin="5">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MenuItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <dx:SimpleButton Command="{Binding DataContext.MenuItemClickCommand, 
                                                                       RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             CommandParameter="{Binding}"
                                                             Margin="5" Width="150" Height="100">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <TextBlock Grid.Row="0" Text="{Binding ItemName}"
                                                               TextWrapping="Wrap" FontSize="14"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Margin="5"/>
                                                    
                                                    <TextBlock Grid.Row="1" Text="{Binding PriceDisplay}"
                                                               FontWeight="Bold" FontSize="16"
                                                               HorizontalAlignment="Center"
                                                               Foreground="Blue"/>
                                                </Grid>
                                            </dx:SimpleButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </dxlc:GroupBox>
                    </Grid>
                    
                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" 
                                  VerticalAlignment="Stretch" ShowsPreview="True"/>
                    
                    <!-- Right Panel - Order List -->
                    <dxlc:GroupBox Grid.Column="2" Header="주문 내역" Margin="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Order Items List -->
                            <dxg:GridControl Grid.Row="0" ItemsSource="{Binding OrderItems}"
                                             ShowBorder="False">
                                <dxg:GridControl.View>
                                    <dxg:TableView ShowGroupPanel="False"
                                                   AllowEditing="False"
                                                   AutoWidth="True">
                                        <dxg:TableView.RowCellMenuCustomizations>
                                            <dxb:BarButtonItem Content="삭제" 
                                                               Command="{Binding DataContext.RemoveOrderItemCommand, 
                                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               CommandParameter="{Binding Row}"/>
                                        </dxg:TableView.RowCellMenuCustomizations>
                                    </dxg:TableView>
                                </dxg:GridControl.View>
                                
                                <dxg:GridColumn FieldName="MenuItemName" Header="메뉴명" Width="*"/>
                                <dxg:GridColumn FieldName="UnitPrice" Header="단가" Width="80">
                                    <dxg:GridColumn.EditSettings>
                                        <dxe:TextEditSettings DisplayFormat="N0" Mask="n0"/>
                                    </dxg:GridColumn.EditSettings>
                                </dxg:GridColumn>
                                <dxg:GridColumn FieldName="Quantity" Header="수량" Width="60">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <dxe:SpinEdit Value="{Binding Row.Quantity, Mode=TwoWay}"
                                                          MinValue="1" MaxValue="99"
                                                          IsTextEditable="False"/>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                                <dxg:GridColumn FieldName="SubTotal" Header="금액" Width="100">
                                    <dxg:GridColumn.EditSettings>
                                        <dxe:TextEditSettings DisplayFormat="N0" Mask="n0"/>
                                    </dxg:GridColumn.EditSettings>
                                </dxg:GridColumn>
                            </dxg:GridControl>
                            
                            <!-- Total Amount -->
                            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="0,1,0,0" 
                                    Margin="0,10,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="합계:" 
                                               FontSize="20" FontWeight="Bold"
                                               HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat='{}{0:N0}원'}"
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="Red"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </dxlc:GroupBox>
                </Grid>
                
                <!-- Bottom Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                    <dx:SimpleButton Content="주문 확정" Command="{Binding ConfirmOrderCommand}"
                                     Glyph="{dx:DXImage Image=Apply_16x16.png}"
                                     Margin="5" Padding="20,10" FontSize="16"/>
                    
                    <dx:SimpleButton Content="결제" Command="{Binding PaymentCommand}"
                                     Glyph="{dx:DXImage Image=Currency_16x16.png}"
                                     Margin="5" Padding="20,10" FontSize="16"/>
                </StackPanel>
            </Grid>
        </dx:DXTabItem>
    </dx:DXTabControl>
</UserControl>