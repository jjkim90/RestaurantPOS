<Window x:Class="RestaurantPOS.WPF.Modules.PaymentHistoryModule.Views.CancelPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="결제 취소 확인" 
        Height="300" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="20">
            <TextBlock Text="결제 취소 확인" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="#333333"/>
        </Border>
        
        <!-- 내용 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" 
                       Text="다음 결제를 취소하시겠습니까?"
                       FontSize="16"
                       Margin="0,0,0,20"/>
            
            <Border Grid.Row="1" 
                    Background="#F9F9F9" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="15"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="{Binding PaymentMethod, StringFormat='결제수단: {0}'}" 
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    
                    <TextBlock Grid.Row="1" 
                               Text="{Binding Amount, StringFormat='결제금액: {0:N0}원'}" 
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2196F3"
                               Margin="0,0,0,5"/>
                    
                    <TextBlock Grid.Row="2" 
                               Text="{Binding PaymentDate, StringFormat='결제일시: {0:yyyy-MM-dd HH:mm:ss}'}" 
                               FontSize="12"
                               Foreground="Gray"/>
                </Grid>
            </Border>
            
            <TextBlock Grid.Row="2" 
                       Text="* 취소된 결제는 복구할 수 없습니다."
                       FontSize="12"
                       Foreground="Red"
                       Margin="0,10,0,0"/>
        </Grid>
        
        <!-- 버튼 영역 -->
        <Grid Grid.Row="2" Background="#F5F5F5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" 
                    Content="취소하기" 
                    Name="ConfirmButton"
                    Click="ConfirmButton_Click"
                    Height="50"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"/>
            
            <Button Grid.Column="1" 
                    Content="닫기" 
                    Name="CancelButton"
                    Click="CancelButton_Click"
                    Height="50"
                    FontSize="16"
                    Background="White"
                    Foreground="#333333"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1,0,0,0"/>
        </Grid>
    </Grid>
</Window>