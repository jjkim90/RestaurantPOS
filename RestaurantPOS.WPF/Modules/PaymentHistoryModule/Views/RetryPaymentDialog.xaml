<Window x:Class="RestaurantPOS.WPF.Modules.PaymentHistoryModule.Views.RetryPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="재결제" 
        Height="700" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="20">
            <TextBlock Text="재결제" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="#333333"/>
        </Border>
        
        <!-- 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
            <!-- 안내 메시지 -->
            <TextBlock Text="취소된 결제를 다시 진행합니다."
                       FontSize="16"
                       Margin="0,0,0,20"/>
            
            <!-- 취소된 결제 정보 -->
            <Border Background="#F9F9F9" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="15"
                    Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="{Binding OriginalPaymentMethod, StringFormat='원래 결제수단: {0}'}" 
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    
                    <TextBlock Text="{Binding Amount, StringFormat='결제금액: {0:N0}원'}" 
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2196F3"
                               Margin="0,0,0,5"/>
                    
                    <TextBlock Text="{Binding CancelledDate, StringFormat='취소일시: {0:yyyy-MM-dd HH:mm:ss}'}" 
                               FontSize="12"
                               Foreground="Gray"
                               Margin="0,0,0,5"/>
                    
                    <TextBlock Text="{Binding CancelReason, StringFormat='취소사유: {0}'}" 
                               FontSize="12"
                               Foreground="Gray"/>
                </StackPanel>
            </Border>
            
            <!-- 결제수단 선택 -->
            <TextBlock Text="새로운 결제수단을 선택하세요"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>
            
            <!-- 현금/카드 버튼 영역 -->
            <Grid Height="80" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 현금 버튼 -->
                <Button Grid.Column="0" 
                        Name="CashButton"
                        Click="CashButton_Click"
                        Height="70"
                        Background="#4CAF50"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Bold">
                    <StackPanel>
                        <TextBlock Text="현금" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cash" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
                
                <!-- 카드 버튼 -->
                <Button Grid.Column="2" 
                        Name="CardButton"
                        Click="CardButton_Click"
                        Height="70"
                        Background="#2196F3"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Bold">
                    <StackPanel>
                        <TextBlock Text="카드" HorizontalAlignment="Center"/>
                        <TextBlock Text="Card" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
            </StackPanel>
        </ScrollViewer>
        
        <!-- 버튼 영역 -->
        <Grid Grid.Row="2" Background="#F5F5F5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" 
                    Content="재결제" 
                    Name="ConfirmButton"
                    Click="ConfirmButton_Click"
                    Height="50"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    IsEnabled="{Binding CanConfirm}"/>
            
            <Button Grid.Column="1" 
                    Content="취소" 
                    Name="CancelButton"
                    Click="CancelButton_Click"
                    Height="50"
                    FontSize="16"
                    Background="White"
                    Foreground="#333333"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1,0,0,0"/>
        </Grid>
    </Grid>
</Window>