<dx:ThemedWindow x:Class="RestaurantPOS.WPF.Modules.TableModule.Views.TableEditDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:prism="http://prismlibrary.com/"
                 prism:ViewModelLocator.AutoWireViewModel="True"
                 Title="{Binding Title}" 
                 Height="300" 
                 Width="400"
                 WindowStartupLocation="CenterOwner"
                 ShowInTaskbar="False">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 테이블 이름 -->
        <Label Grid.Row="0" Content="테이블 이름:" Margin="0,0,0,5"/>
        <dxe:TextEdit Grid.Row="1" 
                      Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}"
                      NullText="테이블 이름을 입력하세요"
                      Margin="0,0,0,10"/>
        
        <!-- 테이블 번호 -->
        <Label Grid.Row="2" Content="테이블 번호:" Margin="0,0,0,5"/>
        <dxe:SpinEdit Grid.Row="3" 
                      Value="{Binding TableNumber}"
                      MinValue="1"
                      MaxValue="999"
                      IsFloatValue="False"
                      Margin="0,0,0,10"/>
        
        <!-- 테이블 상태 -->
        <Label Grid.Row="4" Content="테이블 상태:" Margin="0,0,0,5"/>
        <dxe:ComboBoxEdit Grid.Row="5" 
                          ItemsSource="{Binding TableStatuses}"
                          SelectedItem="{Binding SelectedTableStatus}"
                          DisplayMember="DisplayName"
                          ValueMember="Value"
                          IsEnabled="{Binding IsStatusEditable}"
                          Margin="0,0,0,10"/>
        
        <!-- 버튼 -->
        <StackPanel Grid.Row="7" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <dx:SimpleButton Content="저장" 
                             Command="{Binding SaveCommand}"
                             Width="80" 
                             Height="30" 
                             Margin="0,0,10,0"
                             IsDefault="True"/>
            <dx:SimpleButton Content="취소" 
                             Command="{Binding CancelCommand}"
                             Width="80" 
                             Height="30"
                             IsCancel="True"/>
        </StackPanel>
    </Grid>
</dx:ThemedWindow>