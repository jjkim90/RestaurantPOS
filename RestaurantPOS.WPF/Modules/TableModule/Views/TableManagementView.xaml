<UserControl x:Class="RestaurantPOS.WPF.Modules.TableModule.Views.TableManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:local="clr-namespace:RestaurantPOS.WPF.Modules.TableModule.Views"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1366">
    <UserControl.Resources>
        <!-- Table Tile Style -->
        <Style x:Key="TableTileStyle" TargetType="dxlc:Tile">
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="280"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Size" Value="Small"/>
        </Style>
        
        <!-- Table Content Template -->
        <DataTemplate x:Key="TableContentTemplate">
            <Border BorderBrush="{Binding BorderColor}" 
                    BorderThickness="3" 
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Background="{Binding HeaderColor}"
                            Height="35">
                        <TextBlock Text="{Binding DisplayName}" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                    
                    <!-- Status -->
                    <Grid Grid.Row="1" Background="White" Height="30">
                        <TextBlock Text="{Binding StatusText}" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="Black"/>
                    </Grid>
                    
                    <!-- Order Details List or Empty Space -->
                    <Grid Grid.Row="2" Background="White">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10,5"
                                      Visibility="{Binding AmountVisibility}"
                                      IsHitTestVisible="False">
                            <StackPanel>
                                <!-- 메뉴 목록 -->
                                <ItemsControl ItemsSource="{Binding OrderDetailsList}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" 
                                                       FontSize="12"
                                                       Foreground="DarkSlateGray"
                                                       Margin="0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <!-- 추가 메뉴 표시 -->
                                <TextBlock Text="{Binding MoreItemsText}" 
                                           FontSize="12"
                                           Foreground="Gray"
                                           FontStyle="Italic"
                                           Margin="0,2"
                                           Visibility="{Binding HasMoreItems, Converter={dx:BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- Footer - Total Amount or Empty -->
                    <Border Grid.Row="3" Height="35">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AmountVisibility}" Value="Visible">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding CurrentAmount, StringFormat='합계: ₩{0:N0}'}" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="Black"
                                   Visibility="{Binding AmountVisibility}"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="테이블 관리" 
                           FontSize="24" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0"/>
                
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center"
                            Margin="20,0">
                    <TextBlock Text="{Binding CurrentTime}" 
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="Gray"/>
                    <dx:SimpleButton Content="결제 내역" 
                                     Margin="20,0,0,0"
                                     Width="100"
                                     Height="60"
                                     FontSize="16"
                                     Command="{Binding NavigateToPaymentHistoryCommand}"
                                     dx:ThemeManager.ThemeName="Office2019White"/>
                    <dx:SimpleButton Content="설정" 
                                     Margin="10,0,0,0"
                                     Width="100"
                                     Height="60"
                                     FontSize="16"
                                     Command="{Binding NavigateToSettingsCommand}"
                                     dx:ThemeManager.ThemeName="Office2019White"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Navigation -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Space List -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Spaces}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <dx:SimpleButton Content="{Binding SpaceName}"
                                                     Height="50"
                                                     Margin="5"
                                                     Command="{Binding DataContext.SelectSpaceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- System Space Button -->
                    <dx:SimpleButton Grid.Row="1" 
                                     Content="포장/배달/대기"
                                     Height="50"
                                     Margin="5"
                                     Background="#FFF3E0"
                                     Command="{Binding ShowSystemTablesCommand}"/>
                </Grid>
            </Border>
            
            <!-- Table Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Space Info Bar (Removed Management Buttons) -->
                <Border Grid.Row="0" Background="White" Padding="10" Margin="0,0,0,1">
                    <TextBlock Text="{Binding SelectedSpace.SpaceName, StringFormat='현재 홀: {0}'}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Visibility="{Binding IsSystemTablesMode, Converter={dx:BooleanToVisibilityConverter Invert=True}}"/>
                </Border>
                
                <!-- Content Area -->
                <Grid Grid.Row="1">
                    <!-- Normal Tables View -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="#F0F0F0"
                                  Visibility="{Binding IsSystemTablesMode, Converter={dx:BooleanToVisibilityConverter Invert=True}}">
                        <ItemsControl ItemsSource="{Binding CurrentTables}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <dxlc:Tile Style="{StaticResource TableTileStyle}"
                                               ContentTemplate="{StaticResource TableContentTemplate}"
                                               Content="{Binding}"
                                               Tag="{Binding}">
                                        <dxmvvm:Interaction.Behaviors>
                                            <dxmvvm:EventToCommand EventName="Click" 
                                                                   Command="{Binding DataContext.TableClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                   CommandParameter="{Binding}"
                                                                   PassEventArgsToCommand="False"/>
                                            <dxmvvm:EventToCommand EventName="MouseLeftButtonDown" 
                                                                   Command="{Binding DataContext.SelectTableCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                   CommandParameter="{Binding}"
                                                                   PassEventArgsToCommand="False"/>
                                        </dxmvvm:Interaction.Behaviors>
                                    </dxlc:Tile>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- System Tables View -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="#F0F0F0"
                                  Visibility="{Binding IsSystemTablesMode, Converter={dx:BooleanToVisibilityConverter}}">
                        <StackPanel Margin="20">
                            <!-- 포장 섹션 -->
                            <TextBlock Text="포장" FontSize="18" FontWeight="Bold" Margin="0,10,0,10"/>
                            <ItemsControl ItemsSource="{Binding TakeoutTables}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <dxlc:Tile Width="180" Height="120" Margin="5"
                                                   ContentTemplate="{StaticResource TableContentTemplate}"
                                                   Content="{Binding}"
                                                   Tag="{Binding}">
                                            <dxmvvm:Interaction.Behaviors>
                                                <dxmvvm:EventToCommand EventName="Click" 
                                                                       Command="{Binding DataContext.TableClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                       CommandParameter="{Binding}"
                                                                       PassEventArgsToCommand="False"/>
                                            </dxmvvm:Interaction.Behaviors>
                                        </dxlc:Tile>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- 구분선 -->
                            <Border Height="1" Background="#E0E0E0" Margin="0,20"/>
                            
                            <!-- 대기 섹션 -->
                            <TextBlock Text="대기" FontSize="18" FontWeight="Bold" Margin="0,10,0,10"/>
                            <ItemsControl ItemsSource="{Binding WaitingTables}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <dxlc:Tile Width="180" Height="120" Margin="5"
                                                   ContentTemplate="{StaticResource TableContentTemplate}"
                                                   Content="{Binding}"
                                                   Tag="{Binding}">
                                            <dxmvvm:Interaction.Behaviors>
                                                <dxmvvm:EventToCommand EventName="Click" 
                                                                       Command="{Binding DataContext.TableClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                       CommandParameter="{Binding}"
                                                                       PassEventArgsToCommand="False"/>
                                            </dxmvvm:Interaction.Behaviors>
                                        </dxlc:Tile>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- 구분선 -->
                            <Border Height="1" Background="#E0E0E0" Margin="0,20"/>
                            
                            <!-- 배달 섹션 -->
                            <TextBlock Text="배달" FontSize="18" FontWeight="Bold" Margin="0,10,0,10"/>
                            <ItemsControl ItemsSource="{Binding DeliveryTables}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <dxlc:Tile Width="180" Height="120" Margin="5"
                                                   ContentTemplate="{StaticResource TableContentTemplate}"
                                                   Content="{Binding}"
                                                   Tag="{Binding}">
                                            <dxmvvm:Interaction.Behaviors>
                                                <dxmvvm:EventToCommand EventName="Click" 
                                                                       Command="{Binding DataContext.TableClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                       CommandParameter="{Binding}"
                                                                       PassEventArgsToCommand="False"/>
                                            </dxmvvm:Interaction.Behaviors>
                                        </dxlc:Tile>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>