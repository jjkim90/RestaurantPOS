<dx:ThemedWindow x:Class="RestaurantPOS.WPF.Modules.TableModule.Views.SpaceEditDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                 xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                 xmlns:prism="http://prismlibrary.com/"
                 prism:ViewModelLocator.AutoWireViewModel="True"
                 Title="{Binding Title}" 
                 Height="200" 
                 Width="400"
                 WindowStartupLocation="CenterOwner"
                 ShowInTaskbar="False">
    
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 홀 이름 -->
        <Label Grid.Row="0" Content="홀 이름:" Margin="0,0,0,5"/>
        <dxe:TextEdit Grid.Row="1" 
                      Text="{Binding SpaceName, UpdateSourceTrigger=PropertyChanged}"
                      NullText="홀 이름을 입력하세요"
                      Margin="0,0,0,10"/>
        
        <!-- 활성화 상태 -->
        <dxe:CheckEdit Grid.Row="2" 
                       Content="활성화" 
                       IsChecked="{Binding IsActive}"
                       Margin="0,0,0,10"/>
        
        <!-- 버튼 -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <dx:SimpleButton Content="저장" 
                             Command="{Binding SaveCommand}"
                             Width="80" 
                             Height="30" 
                             Margin="0,0,10,0"
                             IsDefault="True"/>
            <dx:SimpleButton Content="취소" 
                             Command="{Binding CancelCommand}"
                             Width="80" 
                             Height="30"
                             IsCancel="True"/>
        </StackPanel>
    </Grid>
</dx:ThemedWindow>