<prism:PrismApplication x:Class="RestaurantPOS.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPOS.WPF"
             xmlns:converters="clr-namespace:RestaurantPOS.WPF.Converters"
             xmlns:prism="http://prismlibrary.com/">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- DevExpress Theme Resources will be loaded programmatically -->
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <converters:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</prism:PrismApplication>
