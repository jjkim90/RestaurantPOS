<UserControl x:Class="RestaurantPOS.WPF.Controls.PaymentWebView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:local="clr-namespace:RestaurantPOS.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <!-- WebView2 컨트롤 -->
        <wv2:WebView2 x:Name="PaymentWebView2" 
                      Visibility="Collapsed"/>
        
        <!-- 로딩 오버레이 -->
        <local:LoadingOverlay x:Name="LoadingOverlay" 
                             Visibility="Visible"
                             Message="결제창을 준비하고 있습니다..."/>
        
        <!-- 에러 화면 -->
        <Border x:Name="ErrorPanel" 
                Visibility="Collapsed" 
                Background="White">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="오류" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="#ef4444" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,20"/>
                
                <TextBlock x:Name="ErrorMessage" 
                          Text="결제창을 로드하는 중 오류가 발생했습니다." 
                          FontSize="16" 
                          Foreground="#6b7280" 
                          TextWrapping="Wrap" 
                          MaxWidth="400" 
                          TextAlignment="Center" 
                          Margin="0,0,0,30"/>
                
                <Button Content="다시 시도" 
                        Width="120" 
                        Height="40" 
                        Click="RetryButton_Click"
                        Background="#2563eb"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Medium">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>