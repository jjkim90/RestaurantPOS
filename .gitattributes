# Normalize text files by default.
* text=auto

# Keep Windows/.NET project files consistent with the existing repo style.
*.sln text eol=crlf
*.cs text eol=crlf
*.csproj text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.xaml text eol=crlf
*.config text eol=crlf
*.sql text eol=crlf
*.bat text eol=crlf

# Keep docs and Git metadata stable across platforms.
*.md text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# Binary assets must never be normalized.
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
